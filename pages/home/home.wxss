.home { padding-bottom: 40rpx; }
.timer { text-align: center; padding: 80rpx 40rpx 48rpx; color: white; }
.timer-emoji { font-size: 80rpx; display: block; }
.timer-label { font-size: 32rpx; color: rgba(255,255,255,0.7); display: block; margin-top: 16rpx; }
.timer-days { font-size: 112rpx; font-weight: bold; display: block; }
.timer-day-label { font-size: 36rpx; color: rgba(255,255,255,0.7); display: block; }
.timer-date { font-size: 26rpx; color: rgba(255,255,255,0.5); display: block; margin-top: 16rpx; }

.info-row { display: flex; padding: 24rpx 32rpx; gap: 20rpx; margin-top: -24rpx; }
.info-chip { flex: 1; background: white; border-radius: 24rpx; padding: 24rpx 16rpx; text-align: center; box-shadow: 0 4rpx 12rpx rgba(212,238,245,0.4); }
.info-emoji { font-size: 44rpx; display: block; }
.info-val { font-size: 26rpx; font-weight: 600; display: block; margin-top: 8rpx; }
.info-lbl { font-size: 22rpx; color: #8E9AAF; display: block; }

.mood-card { margin: 4rpx 32rpx 20rpx; }
.mood-title { font-size: 26rpx; color: #8E9AAF; margin-bottom: 16rpx; display: block; }
.mood-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.mood-item { font-size: 48rpx; padding: 12rpx 16rpx; border-radius: 20rpx; background: rgba(255,255,255,0.25); }
.mood-item.active { background: white; border: 2rpx solid #7EC8E3; }

.quote-card { margin: 0 32rpx 20rpx; }
.quote-header { display: flex; justify-content: space-between; font-size: 26rpx; color: #8E9AAF; margin-bottom: 16rpx; }
.refresh { color: #7EC8E3; }
.quote-text { font-size: 30rpx; line-height: 1.6; text-align: center; display: block; }

.nav-grid { display: flex; flex-wrap: wrap; padding: 0 24rpx; }
.nav-item { width: calc(50% - 24rpx); margin: 12rpx; background: white; border-radius: 24rpx; padding: 28rpx; box-shadow: 0 4rpx 12rpx rgba(212,238,245,0.4); }
.nav-emoji { font-size: 56rpx; display: block; }
.nav-name { font-size: 30rpx; font-weight: 600; display: block; margin-top: 16rpx; }
.nav-desc { font-size: 24rpx; color: #8E9AAF; display: block; margin-top: 8rpx; }

.logout-link { text-align: center; color: #FF6B8A; font-size: 28rpx; margin-top: 32rpx; }
