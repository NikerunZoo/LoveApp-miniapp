/* ===== 首页 ===== */
.home { min-height: 100vh; background: #F7F9FC; padding-bottom: 40rpx; }

/* ---- 计时器 ---- */
.timer-section {
  background: linear-gradient(155deg, #6DB8D4 0%, #7EC8E3 25%, #A8D8EA 60%, #C5E8F3 100%);
  padding: 72rpx 0 56rpx;
  text-align: center;
  border-radius: 0 0 64rpx 64rpx;
  position: relative;
  overflow: hidden;
}
.timer-glow {
  position: absolute;
  top: -40%;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
  border-radius: 50%;
}
.timer-label { color: rgba(255,255,255,0.85); font-size: 28rpx; display: block; position: relative; z-index: 1; }
.timer-days-row { display: flex; align-items: baseline; justify-content: center; margin: 16rpx 0; position: relative; z-index: 1; }
.timer-number { color: white; font-size: 140rpx; font-weight: 200; line-height: 1; letter-spacing: -4rpx; }
.timer-unit { color: rgba(255,255,255,0.8); font-size: 36rpx; margin-left: 12rpx; }
.timer-date { color: rgba(255,255,255,0.6); font-size: 24rpx; display: block; position: relative; z-index: 1; }
.timer-wave { display: flex; justify-content: center; gap: 8rpx; margin-top: 32rpx; position: relative; z-index: 1; }
.wave { width: 8rpx; height: 8rpx; background: rgba(255,255,255,0.5); border-radius: 50%; }
.wave:nth-child(1) { animation: wave 1.5s ease-in-out infinite; }
.wave:nth-child(2) { animation: wave 1.5s ease-in-out 0.3s infinite; }
.wave:nth-child(3) { animation: wave 1.5s ease-in-out 0.6s infinite; }
@keyframes wave {
  0%,100% { transform: translateY(0); opacity: 0.5; }
  50% { transform: translateY(-12rpx); opacity: 1; }
}

/* ---- 三列信息卡 ---- */
.info-strip {
  display: flex;
  margin: -32rpx 32rpx 28rpx;
  background: white;
  border-radius: 32rpx;
  padding: 28rpx 0;
  box-shadow: 0 8rpx 36rpx rgba(126,200,227,0.2);
  position: relative;
  z-index: 2;
}
.info-item { flex: 1; text-align: center; }
.info-item:active { opacity: 0.7; }
.info-emoji { font-size: 40rpx; display: block; }
.info-value { font-size: 28rpx; font-weight: 600; color: #2D3E4F; margin-top: 6rpx; display: block; }
.info-label { font-size: 22rpx; color: #8E9AAF; margin-top: 4rpx; display: block; }
.info-divider { width: 2rpx; height: 48rpx; background: #F0F4F8; align-self: center; }

/* ---- 章节标题 ---- */
.section-title { font-size: 30rpx; font-weight: 600; color: #2D3E4F; padding: 28rpx 32rpx 16rpx; }

/* ---- 心情 ---- */
.mood-grid {
  display: flex; flex-wrap: wrap; gap: 12rpx;
  padding: 0 32rpx; margin-bottom: 28rpx;
}
.mood-chip {
  width: calc(25% - 9rpx);
  aspect-ratio: 1;
  background: white;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
  position: relative;
}
.mood-chip.active {
  background: #7EC8E3;
  box-shadow: 0 6rpx 20rpx rgba(126,200,227,0.3);
}
.mood-chip.active::after {
  content: '✓';
  position: absolute; top: 4rpx; right: 8rpx;
  font-size: 20rpx; color: white;
}
.mood-chip:active { transform: scale(0.92); }

/* ---- 情话 ---- */
.quote-card { padding: 0 32rpx; margin-bottom: 28rpx; }
.quote-inner {
  background: linear-gradient(135deg, #F0F7FA 0%, #FAFCFD 100%);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  border: 2rpx solid #E8F4F8;
  position: relative;
}
.quote-icon { font-size: 48rpx; display: block; margin-bottom: 16rpx; }
.quote-text { font-size: 30rpx; color: #4A6578; line-height: 1.8; display: block; }
.quote-refresh { margin-top: 20rpx; font-size: 24rpx; color: #7EC8E3; }

/* ---- 配对头部 ---- */
.pair-header {
  background: linear-gradient(155deg, #6DB8D4 0%, #7EC8E3 25%, #A8D8EA 60%, #C5E8F3 100%);
  padding: 80rpx 32rpx 56rpx;
  text-align: center;
  border-radius: 0 0 64rpx 64rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.pair-glow {
  position: absolute;
  top: -40%;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
  border-radius: 50%;
}
.pair-emoji { font-size: 96rpx; display: block; position: relative; z-index: 1; }
.pair-title { color: white; font-size: 40rpx; font-weight: 600; display: block; margin-top: 16rpx; position: relative; z-index: 1; }
.pair-sub { color: rgba(255,255,255,0.7); font-size: 26rpx; display: block; margin-top: 12rpx; position: relative; z-index: 1; }

/* ---- 配对卡片 ---- */
.pair-card {
  margin: 0 28rpx 24rpx;
  background: white;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 36rpx rgba(126,200,227,0.15);
}
.date-picker {
  background: #F7F9FC;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  font-size: 30rpx;
  text-align: center;
  color: #2D3E4F;
}

/* 配对码展示 */
.code-box {
  background: linear-gradient(155deg, #6DB8D4, #7EC8E3, #A8D8EA);
  border-radius: 40rpx;
  padding: 64rpx 40rpx;
  text-align: center;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(126,200,227,0.3);
}
.code-label { color: rgba(255,255,255,0.8); font-size: 28rpx; display: block; }
.code { color: white; font-size: 88rpx; font-weight: 200; letter-spacing: 20rpx; display: block; margin: 24rpx 0; }
.code-hint { color: rgba(255,255,255,0.5); font-size: 24rpx; display: block; }
.code-actions { text-align: center; }

/* 配对码输入 */
.code-input {
  background: #F7F9FC;
  padding: 36rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 64rpx;
  letter-spacing: 28rpx;
  margin-bottom: 32rpx;
  width: 100%;
  box-sizing: border-box;
}
