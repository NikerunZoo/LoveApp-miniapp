.splash {
  height: 100vh;
  background: linear-gradient(180deg, #7EC8E3, #A8D8EA);
  display: flex;
  align-items: center;
  justify-content: center;
}
.splash-content { text-align: center; }
.splash-emoji { font-size: 128rpx; display: block; }
.splash-title { color: white; font-size: 56rpx; font-weight: bold; margin-top: 32rpx; display: block; }
.splash-sub { color: rgba(255,255,255,0.7); font-size: 28rpx; margin-top: 16rpx; display: block; }
