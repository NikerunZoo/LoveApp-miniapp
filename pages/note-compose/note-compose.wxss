.compose { padding: 32rpx; display: flex; flex-direction: column; height: calc(100vh - 88rpx); }
.content { flex: 1; font-size: 32rpx; line-height: 1.6; padding: 24rpx; background: white; border-radius: 24rpx; margin-bottom: 24rpx; }
.phrases { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.phrase { background: #D4EEF5; padding: 14rpx 24rpx; border-radius: 32rpx; font-size: 26rpx; }
.accent-btn { background: #FF6B8A !important; color: white !important; border-radius: 24rpx; font-size: 32rpx; }
