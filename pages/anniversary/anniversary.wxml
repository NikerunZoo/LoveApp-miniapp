<view class="container">
  <!-- 我们在一起 — 主卡片 -->
  <view class="main-card" bindtap="editStartDate">
    <text class="main-emoji">💕</text>
    <text class="main-title">我们在一起</text>
    <text class="main-date">{{startDateStr}}</text>
    <view class="main-stats">
      <view class="stat"><text class="stat-val">第 {{yearCount}} 年</text><text class="stat-lbl">在一起</text></view>
      <view class="stat"><text class="stat-val">还剩 {{daysToNext}} 天</text><text class="stat-lbl">纪念日</text></view>
    </view>
  </view>

  <!-- 自定义纪念日列表 -->
  <block wx:for="{{anniversaries}}" wx:key="id">
    <view class="anniv-card" data-item="{{item}}" bindlongpress="deleteItem">
      <text class="anniv-emoji">🎉</text>
      <view class="anniv-info">
        <text class="anniv-name">{{item.title}}</text>
        <text class="anniv-date">{{item.date}}</text>
      </view>
    </view>
  </block>

  <button class="btn-outline" bindtap="add">+ 添加纪念日</button>
  <view class="hint" wx:if="{{anniversaries.length>0}}">💡 长按可删除</view>
</view>
