.anniv-scroll { background: #F7F9FC; min-height: 100vh; padding: 28rpx; }
.main-card {
  background: linear-gradient(155deg, #6DB8D4 0%, #7EC8E3 40%, #A8D8EA 100%);
  border-radius: 36rpx; padding: 48rpx; text-align: center;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(126,200,227,0.3);
  position: relative; overflow: hidden;
}
.main-card::after {
  content: ''; position: absolute; top: -20%; right: -15%;
  width: 300rpx; height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
  border-radius: 50%;
}
.main-emoji { font-size: 64rpx; display: block; position: relative; z-index: 1; }
.main-title { color: white; font-size: 30rpx; font-weight: 600; display: block; margin-top: 12rpx; position: relative; z-index: 1; }
.main-date { color: rgba(255,255,255,0.7); font-size: 26rpx; display: block; margin-top: 8rpx; position: relative; z-index: 1; }
.main-edit { display: inline-block; color: rgba(255,255,255,0.7); font-size: 22rpx; margin-top: 12rpx; padding: 6rpx 20rpx; background: rgba(255,255,255,0.15); border-radius: 20rpx; position: relative; z-index: 1; }
.main-stats { display: flex; justify-content: space-around; margin-top: 32rpx; position: relative; z-index: 1; }
.main-stat { text-align: center; }
.main-stat-val { color: white; font-size: 40rpx; font-weight: 200; display: block; }
.main-stat-lbl { color: rgba(255,255,255,0.7); font-size: 24rpx; display: block; margin-top: 4rpx; }

.anniv-item {
  display: flex; align-items: center; padding: 28rpx;
  background: white; border-radius: 28rpx; margin-bottom: 12rpx;
  box-shadow: 0 2rpx 16rpx rgba(126,200,227,0.08);
  gap: 28rpx;
}
.anniv-emoji { font-size: 48rpx; }
.anniv-info { flex: 1; }
.anniv-name { font-size: 30rpx; font-weight: 600; display: block; }
.anniv-date-str { font-size: 24rpx; color: #8E9AAF; display: block; margin-top: 4rpx; }
.anniv-days-badge {
  background: linear-gradient(135deg, #7EC8E3, #A8D8EA);
  color: white; padding: 12rpx 24rpx; border-radius: 24rpx;
  font-size: 24rpx; white-space: nowrap;
}

/* ---- 弹窗 ---- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-box {
  background: white;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 32rpx;
  width: 580rpx;
}
.modal-title { font-size: 34rpx; font-weight: 600; color: #2D3E4F; display: block; text-align: center; margin-bottom: 32rpx; }
.modal-input {
  background: #F7F9FC;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}
.modal-date-picker {
  background: #F7F9FC;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  text-align: center;
  color: #2D3E4F;
  margin-bottom: 8rpx;
}
.modal-btns { display: flex; gap: 20rpx; margin-top: 28rpx; }
.modal-btn-cancel {
  flex: 1;
  background: #F0F4F8;
  color: #8E9AAF;
  border-radius: 999rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  border: none;
}
.modal-btn-confirm {
  flex: 1;
  background: linear-gradient(135deg, #7EC8E3, #5BA4C0);
  color: white;
  border-radius: 999rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  border: none;
}
