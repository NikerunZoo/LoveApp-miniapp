.main-card { background: linear-gradient(180deg,#7EC8E3,#A8D8EA); border-radius: 28rpx; padding: 48rpx; text-align: center; margin-bottom: 24rpx; }
.main-emoji { font-size: 64rpx; display: block; }
.main-title { color: white; font-size: 32rpx; font-weight: 600; display: block; margin-top: 16rpx; }
.main-date { color: rgba(255,255,255,0.7); font-size: 26rpx; display: block; margin-top: 8rpx; }
.main-stats { display: flex; justify-content: space-around; margin-top: 24rpx; }
.stat { text-align: center; }
.stat-val { color: white; font-size: 36rpx; font-weight: bold; display: block; }
.stat-lbl { color: rgba(255,255,255,0.7); font-size: 24rpx; display: block; }
.anniv-card { display: flex; align-items: center; padding: 28rpx; background: white; border-radius: 24rpx; margin-bottom: 12rpx; box-shadow: 0 4rpx 12rpx rgba(212,238,245,0.4); }
.anniv-emoji { font-size: 48rpx; }
.anniv-info { margin-left: 24rpx; }
.anniv-name { font-size: 30rpx; font-weight: 600; display: block; }
.anniv-date { font-size: 24rpx; color: #8E9AAF; display: block; margin-top: 6rpx; }
.btn-outline { background: transparent; border: 2rpx solid #7EC8E3; color: #7EC8E3; border-radius: 24rpx; text-align: center; padding: 20rpx; font-size: 28rpx; margin-top: 16rpx; }
.hint { text-align: center; color: #8E9AAF; font-size: 24rpx; padding: 20rpx; }
