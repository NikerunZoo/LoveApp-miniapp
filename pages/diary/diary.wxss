.diary-scroll { background: #F7F9FC; min-height: 100vh; }
.diary-card {
  background: white; border-radius: 28rpx; padding: 28rpx;
  margin: 0 28rpx 16rpx; box-shadow: 0 2rpx 16rpx rgba(126,200,227,0.08);
  position: relative;
}
.diary-card::before {
  content: ''; position: absolute; left: 0; top: 20rpx; bottom: 20rpx;
  width: 6rpx; border-radius: 3rpx;
  background: linear-gradient(180deg, #7EC8E3, #D4EEF5);
}
.diary-head { display: flex; align-items: center; gap: 12rpx; margin-bottom: 14rpx; margin-left: 18rpx; }
.diary-mood { font-size: 40rpx; }
.diary-who { font-size: 26rpx; font-weight: 600; }
.diary-who.me { color: #7EC8E3; }
.diary-who.ta { color: #FF6B8A; }
.diary-content { font-size: 30rpx; line-height: 1.7; display: block; margin-left: 18rpx; color: #4A6578; }
.diary-time { font-size: 22rpx; color: #B0BEC5; margin-top: 14rpx; display: block; margin-left: 18rpx; }
