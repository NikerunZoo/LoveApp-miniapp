<view class="album-scroll">
  <view class="album-toolbar">
    <button class="btn-primary" bindtap="chooseImage">📷 上传照片</button>
  </view>
  <block wx:if="{{loading}}"><view class="empty-state"><text class="emoji">🖼️</text><text class="title">加载中...</text></view></block>
  <block wx:elif="{{photos.length===0}}">
    <view class="empty-state"><text class="emoji">🖼️</text><text class="title">还没有照片</text><text class="sub">点击上方按钮上传第一张照片吧</text></view>
  </block>
  <view wx:else class="photo-grid">
    <view wx:for="{{photos}}" wx:key="id" class="photo-item" data-photo="{{item}}" data-url="{{item.url}}" bindtap="preview" bindlongpress="deletePhoto">
      <image class="photo-img" src="{{item.url}}" mode="aspectFill" lazy-load></image>
      <view class="photo-tag">{{item.user_id === currentUserId ? '我' : 'TA'}}</view>
    </view>
  </view>
  <view class="hint-text" wx:if="{{photos.length>0}}">💡 长按照片可删除（仅自己的）</view>
  <view style="height:80rpx;"></view>
</view>
