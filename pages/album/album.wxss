.album-scroll { background: #F7F9FC; min-height: 100vh; }
.album-toolbar { padding: 28rpx; }
.photo-grid { display: flex; flex-wrap: wrap; padding: 0 20rpx; gap: 12rpx; }
.photo-item {
  width: calc(33.33% - 8rpx); position: relative;
  border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.photo-img { width: 100%; height: 240rpx; display: block; }
.photo-tag {
  position: absolute; top: 8rpx; right: 8rpx;
  background: rgba(0,0,0,0.35); color: white;
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 12rpx;
  backdrop-filter: blur(8rpx);
}
