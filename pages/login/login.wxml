<view class="login-page">
  <view class="login-blob"></view>
  <view class="login-card">
    <text class="login-emoji">💕</text>
    <text class="login-title">属于我们</text>
    <text class="login-sub">两个人的小世界</text>

    <view class="login-form">
      <block wx:if="{{isRegister}}">
        <input class="input-field" placeholder="昵称 (如: 宝贝)" value="{{nickname}}" bindinput="onNicknameInput" />
      </block>
      <input class="input-field" type="text" placeholder="邮箱" value="{{email}}" bindinput="onEmailInput" />
      <input class="input-field" type="password" placeholder="密码 (至少6位)" value="{{password}}" bindinput="onPasswordInput" />

      <button class="btn-primary login-btn" loading="{{loading}}" bindtap="handleSubmit">
        {{isRegister ? '注册' : '登录'}}
      </button>
    </view>

    <text class="toggle-link" bindtap="toggleMode">
      {{isRegister ? '已有账号? 去登录' : '没有账号? 去注册'}}
    </text>
  </view>
</view>
