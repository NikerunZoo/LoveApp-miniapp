<view class="login-page">
  <view class="login-card">
    <text class="emoji">💕</text>
    <text class="title">属于我们</text>

    <block wx:if="{{isRegister}}">
      <input class="input" placeholder="昵称（如：宝贝）" value="{{nickname}}" bindinput="e => nickname = e.detail.value" />
    </block>

    <input class="input" type="text" placeholder="邮箱" value="{{email}}" bindinput="e => email = e.detail.value" />
    <input class="input" type="password" placeholder="密码（至少6位）" value="{{password}}" bindinput="e => password = e.detail.value" />

    <button class="btn-primary" loading="{{loading}}" bindtap="handleSubmit">
      {{isRegister ? '注册' : '登录'}}
    </button>

    <text class="toggle-link" bindtap="toggleMode">
      {{isRegister ? '已有账号？去登录' : '没有账号？去注册'}}
    </text>
  </view>
</view>
