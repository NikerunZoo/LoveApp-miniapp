.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #A8D8EA, #D4EEF5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}
.login-card { width: 100%; max-width: 600rpx; text-align: center; }
.emoji { font-size: 96rpx; display: block; }
.title { font-size: 48rpx; font-weight: bold; color: #7EC8E3; display: block; margin: 24rpx 0 48rpx; }
.input {
  background: white;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
}
.toggle-link { color: #7EC8E3; font-size: 28rpx; margin-top: 32rpx; display: block; }
