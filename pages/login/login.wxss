.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #7EC8E3, #A8D8EA 50%, #D4EEF5 100%);
  display: flex; align-items: center; justify-content: center;
  padding: 48rpx; position: relative; overflow: hidden;
}
.login-blob {
  position: absolute; width: 600rpx; height: 600rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  top: -20%; left: -30%; border-radius: 50%;
}
.login-card { width: 100%; max-width: 600rpx; text-align: center; position: relative; z-index: 1; }
.login-emoji { font-size: 96rpx; display: block; }
.login-title { font-size: 52rpx; font-weight: 700; color: white; display: block; margin-top: 16rpx; letter-spacing: 8rpx; }
.login-sub { font-size: 28rpx; color: rgba(255,255,255,0.7); display: block; margin: 12rpx 0 48rpx; }
.login-form { display: flex; flex-direction: column; gap: 20rpx; }
.login-btn { margin-top: 12rpx; }
.toggle-link { color: rgba(255,255,255,0.85); font-size: 28rpx; margin-top: 48rpx; display: block; }
