/* ===== LoveApp 全局视觉系统 ===== */
/* 配色: 暮光蓝 + 珊瑚粉 + 柔和白 */

page {
  --primary: #7EC8E3;
  --primary-dark: #5BA4C0;
  --primary-light: #D4EEF5;
  --accent: #FF6B8A;
  --accent-glow: rgba(255,107,138,0.25);
  --bg: #F7F9FC;
  --card: #FFFFFF;
  --text: #2D3E4F;
  --text-light: #8E9AAF;
  --text-muted: #B0BEC5;
  --shadow-sm: 0 2rpx 16rpx rgba(126,200,227,0.12);
  --shadow-md: 0 8rpx 32rpx rgba(126,200,227,0.18);
  --shadow-lg: 0 16rpx 48rpx rgba(0,0,0,0.08);
  --radius-sm: 16rpx;
  --radius: 28rpx;
  --radius-lg: 40rpx;
  --radius-full: 999rpx;

  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
}

/* ===== 通用卡片 ===== */
.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 32rpx;
  margin: 0 28rpx 24rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.card:active { transform: scale(0.985); box-shadow: var(--shadow-md); }

/* ===== 渐变头部 ===== */
.gradient-header {
  background: linear-gradient(155deg, #7EC8E3 0%, #A8D8EA 40%, #D4EEF5 100%);
  border-radius: 0 0 56rpx 56rpx;
  position: relative;
  overflow: hidden;
}
.gradient-header::after {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

/* ===== 按钮系统 ===== */
.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: white;
  border-radius: var(--radius-full);
  padding: 26rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(126,200,227,0.35);
  border: none;
  transition: all 0.2s ease;
}
.btn-primary:active { transform: scale(0.97); opacity: 0.9; }

.btn-accent {
  background: linear-gradient(135deg, var(--accent) 0%, #FF8FA5 100%);
  color: white;
  border-radius: var(--radius-full);
  padding: 26rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx var(--accent-glow);
  border: none;
}
.btn-accent:active { transform: scale(0.97); opacity: 0.9; }

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--primary);
  color: var(--primary);
  border-radius: var(--radius-full);
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
}

/* ===== 输入框 ===== */
.input-field {
  background: var(--card);
  border-radius: var(--radius);
  padding: 26rpx 32rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}
.input-field:focus { border-color: var(--primary); }

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}
.empty-state .emoji { font-size: 120rpx; margin-bottom: 32rpx; opacity: 0.8; }
.empty-state .title { font-size: 32rpx; color: var(--text-light); font-weight: 500; }
.empty-state .sub { font-size: 26rpx; color: var(--text-muted); margin-top: 12rpx; }

/* ===== 浮动按钮 ===== */
.fab {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  width: 104rpx;
  height: 104rpx;
  background: linear-gradient(135deg, var(--accent) 0%, #FF8FA5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: white;
  box-shadow: 0 12rpx 36rpx var(--accent-glow);
  z-index: 100;
}
.fab:active { transform: scale(0.9); }

/* ===== Tab 切换 ===== */
.tab-bar {
  display: flex;
  background: var(--primary-light);
  border-radius: var(--radius-full);
  padding: 6rpx;
  margin: 0 28rpx 24rpx;
}
.tab-bar .tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: var(--text-light);
  border-radius: var(--radius-full);
  transition: all 0.25s ease;
}
.tab-bar .tab.active {
  background: white;
  color: var(--primary);
  font-weight: 600;
  box-shadow: var(--shadow-sm);
}

/* ===== 提示文字 ===== */
.hint-text {
  text-align: center;
  color: var(--text-muted);
  font-size: 24rpx;
  padding: 24rpx 0;
}
