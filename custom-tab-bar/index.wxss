.tab-bar-wrap {
  display: flex;
  background: #FFFFFF;
  border-top: 2rpx solid #F0F4F8;
  padding: 8rpx 0;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  position: relative;
  transition: all 0.2s ease;
}

.tab-icon {
  font-size: 40rpx;
  display: block;
  transition: transform 0.2s ease;
}

.tab-text {
  font-size: 20rpx;
  color: #B0BEC5;
  margin-top: 2rpx;
  transition: color 0.2s ease;
}

.tab-active .tab-text {
  color: #7EC8E3;
}

.tab-active .tab-icon {
  transform: scale(1.15);
}

.tab-dot {
  position: absolute;
  bottom: -4rpx;
  width: 8rpx;
  height: 6rpx;
  background: #7EC8E3;
  border-radius: 3rpx;
}

.tab-item:active {
  opacity: 0.7;
}
